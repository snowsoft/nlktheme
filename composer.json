{
    "name": "snowsoft/nlktheme",
    "description": "FlexPage-style JSON-driven hybrid theme engine for Laravel 13",
    "keywords": ["laravel", "theme", "shopify", "pagebuilder", "json", "sections"],
    "homepage": "https://github.com/snowsoft/nlktheme",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "nlksoft",
            "email": "info@nlksoft.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "laravel/framework": "^13.0",
        "matthiasmullie/minify": "*",
        "nesbot/carbon": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Nlk\\Theme\\": "src/"
        },
        "classmap": [
            "src/Exceptions.php"
        ],
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Nlk\\Theme\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nlk\\Theme\\ThemeServiceProvider"
            ],
            "aliases": {
                "Theme": "Nlk\\Theme\\Facades\\Theme",
                "PageBuilder": "Nlk\\Theme\\Facades\\PageBuilder"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}